# UniForms – example environment configuration
# Copy this file to .env and adjust the values before first run.

# ── JWT ───────────────────────────────────────────────────────────────────
# IMPORTANT: Set a strong random secret in production!
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production-use-strong-random-key
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=480

# ── Initial admin account ─────────────────────────────────────────────────
# Used only on first run when the database does not yet exist.
# Role assigned: system_admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ── Auth provider ─────────────────────────────────────────────────────────
# Options: simple | oauth | ldap   (default: simple)
# AUTH_PROVIDER=simple

# ── Paths (optional – can also be changed in the Settings UI) ─────────────
# DATABASE_PATH=data/uniforms.db
# DEFAULT_RECORDS_DIR=data/records
# DEFAULT_SCHEMAS_DIR=data/schemas
# DEFAULT_COLLECTIONS_DIR=data/collections
