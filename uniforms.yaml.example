# =============================================================================
# UniForms – Deployment Configuration Example
# =============================================================================
# Copy this file to uniforms.yaml and customize for your domain.
# uniforms.yaml is the only configuration file for a UniForms deployment.
# Secrets (JWT keys, passwords) go in .env – never in this file.
# =============================================================================

app:
  name: "UniForms"
  subtitle: "Universal Forms Engine"

# ---------------------------------------------------------------------------
# Terminology – how the UI refers to entities in your domain.
# Customize every label to match your language and domain conventions.
# ---------------------------------------------------------------------------
terminology:
  # Core entity names
  record_id_label: "Record ID"

  # Page subtitles (shown under page headings)
  records_subtitle: "All records"
  templates_subtitle: "Available templates"
  dashboard_subtitle: "Overview"

  # Action buttons
  new_record_btn: "New Record"       # button label on templates list
  coordinator_label: "Coordinator"   # field label for the responsible person
  take_over_btn: "Take Over"         # button to assign a record to yourself

  # Status labels (shown as badges on template cards)
  status_active: "Active"
  status_draft: "Draft"
  status_deprecated: "Deprecated"

  # Sidebar navigation labels
  nav_dashboard: "Dashboard"
  nav_users: "Users"
  nav_settings: "Settings"

# ---------------------------------------------------------------------------
# Record ID generation.
# Available tokens: {prefix}, {DDMMYYYY}, {YYYYMM}, {YYYY}, {MM}, {DD}, {HHMM}, {rand:04d}
# ---------------------------------------------------------------------------
id:
  prefix: "REC"
  format: "{prefix}-{YYYYMM}-{rand:04d}"   # REC-202603-0042

# ---------------------------------------------------------------------------
# Default workflow states – used when a template does not define its own workflow.
# Per-template workflow is defined in the template YAML under the 'workflow' key.
# color: Bootstrap contextual color – primary, secondary, success, danger, warning, info, dark
# ---------------------------------------------------------------------------
workflow:
  default_states:
    - id: new
      label: "New"
      color: secondary
    - id: open
      label: "Open"
      color: primary
    - id: in_progress
      label: "In Progress"
      color: warning
    - id: on_hold
      label: "On Hold"
      color: info
    - id: closed
      label: "Closed"
      color: success
  initial_state: new

# ---------------------------------------------------------------------------
# Extensions – domain-specific section types, templates, and JS renderers.
# Each extension is a directory containing an extension.yaml manifest.
# ---------------------------------------------------------------------------
extensions: []
# extensions:
#   - id: soc
#     path: extensions/soc

