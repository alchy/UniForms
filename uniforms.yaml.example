# =============================================================================
# UniForms – ukázková konfigurace nasazení (uniforms.yaml)
# =============================================================================
# Zkopíruj do uniforms.yaml a přizpůsob své doméně.
# Všechny klíče jsou VOLITELNÉ – když soubor chybí nebo klíč neuvedeš,
# použije se výchozí hodnota z kódu (app/config.py).
# Tajné hodnoty (JWT klíč, hesla) patří do .env – nikdy sem.
# =============================================================================

app:
  name: "UniForms"
  subtitle: "Universal Forms Engine"

# ---------------------------------------------------------------------------
# Terminologie – doménové pojmy zobrazované v UI.
# Stačí přepsat jen to, co se ve tvé doméně jmenuje jinak; kompletní katalog
# všech přepsatelných UI textů najdeš v TerminologyConfig (app/config.py).
# Každá kolekce může kterýkoli klíč přepsat ve svém YAML pod `terminology:`.
# ---------------------------------------------------------------------------
terminology:
  record_id_label: "Record ID"        # označení ID záznamu (Ticket ID, Case ID…)
  record_owner_label: "Record Owner"  # vlastník / řešitel záznamu
  new_record_btn: "New Record"        # tlačítko založení záznamu
  take_over_btn: "Take Over"          # tlačítko převzetí záznamu
  records_subtitle: "All records"
  templates_subtitle: "Available templates"
  dashboard_subtitle: "Overview"

# ---------------------------------------------------------------------------
# Generování ID záznamu.
# Tokeny: {prefix}, {DDMMYYYY}, {YYYYMM}, {YYYY}, {MM}, {DD}, {HHMM}, {rand:04d}
# Kolekce může formát přepsat ve svém YAML pod `id_format:`.
# ---------------------------------------------------------------------------
id:
  prefix: "REC"
  format: "{prefix}-{YYYYMM}-{rand:04d}"   # REC-202603-0042

# ---------------------------------------------------------------------------
# Výchozí workflow stavy – použijí se, když kolekce nedefinuje vlastní.
# Stejná struktura jako `workflow:` v collection YAML (docs/KOLEKCE.md).
# color: Bootstrap varianta (primary, secondary, success, danger, warning,
#        info, dark) NEBO libovolná CSS barva (green, #e74c3c, steelblue…)
# ---------------------------------------------------------------------------
workflow:
  initial_state: new
  states:
    - { id: new,         label: "New",         color: secondary }
    - { id: open,        label: "Open",        color: primary }
    - { id: in_progress, label: "In Progress", color: warning }
    - { id: on_hold,     label: "On Hold",     color: info }
    - { id: closed,      label: "Closed",      color: success }

# =============================================================================
# Příklad: IT ServiceDesk
# =============================================================================
#
# app:
#   name: "IT ServiceDesk"
#   subtitle: "IT Ticket Management"
#
# terminology:
#   record_id_label: "Ticket ID"
#   record_owner_label: "Assigned To"
#   new_record_btn: "New Ticket"
#   take_over_btn: "Assign to Me"
#
# id:
#   prefix: "TKT"
#   format: "{prefix}-{YYYYMM}-{rand:04d}"
#
# workflow:
#   initial_state: new
#   states:
#     - { id: new,         label: "New",         color: secondary }
#     - { id: assigned,    label: "Assigned",    color: primary }
#     - { id: in_progress, label: "In Progress", color: warning }
#     - { id: resolved,    label: "Resolved",    color: success }
#     - { id: closed,      label: "Closed",      color: dark }

